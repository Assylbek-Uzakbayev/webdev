        {"name": "Update Product", "request": {"method": "PUT", "url": "http://127.0.0.1:8000/api/products/6/", "body": {"mode": "raw", "raw": "{\"name\": \"Updated Product\", \"price\": 199.99, \"description\": \"Updated\", \"count\": 10, \"is_active\": true, \"category\": 2}", "options": {"raw": {"language": "json"}}}}},
