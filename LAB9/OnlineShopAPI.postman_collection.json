        {"name": "Update Category", "request": {"method": "PUT", "url": "http://127.0.0.1:8000/api/categories/1/", "body": {"mode": "raw", "raw": "{\"name\": \"Electronics Updated\"}", "options": {"raw": {"language": "json"}}}}},
